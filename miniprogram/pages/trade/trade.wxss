.trade-page {
  width: 750rpx;
  min-height: 100vh;
  overflow-x: hidden;
  padding-bottom: 34rpx;
  color: #573719;
  background: linear-gradient(180deg, #e6bd86 0%, #fff2df 48%, #fffaf2 100%);
}

.trade-hero {
  position: relative;
  width: 750rpx;
  height: 562rpx;
  overflow: hidden;
}

.trade-room-bg {
  position: absolute;
  inset: 0;
  width: 750rpx;
  height: 562rpx;
}

.trade-hero-mask {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(255, 229, 191, 0.28), rgba(138, 82, 36, 0.12) 58%, rgba(240, 198, 140, 0.28)),
    radial-gradient(circle at 72% 18%, rgba(255, 249, 220, 0.38), transparent 30%);
}

.trade-nav {
  position: relative;
  z-index: 4;
  padding: 42rpx 24rpx 0;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.trade-title-row {
  min-width: 0;
  flex: 1;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.trade-back {
  width: 70rpx;
  height: 70rpx;
  flex: 0 0 70rpx;
  padding: 0;
  border: 0;
  border-radius: 50%;
  background: rgba(255, 248, 234, 0.96);
  color: #8a5a27;
  font-size: 54rpx;
  font-weight: 700;
  line-height: 62rpx;
  box-shadow: 0 8rpx 18rpx rgba(81, 47, 19, 0.16);
}

.trade-back::after,
.trade-help::after,
.trade-tab::after,
.trade-row-action::after,
.trade-more-button::after,
.trade-switch-button::after,
.trade-continue-button::after {
  border: 0;
}

.trade-title-copy {
  min-width: 0;
}

.trade-heading-line {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.trade-title {
  max-width: 350rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #5d3618;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 40rpx;
}

.trade-help {
  width: 36rpx;
  height: 36rpx;
  padding: 0;
  border-radius: 50%;
  background: rgba(255, 250, 236, 0.9);
  color: #ac834e;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 36rpx;
}

.trade-subtitle {
  display: block;
  margin-top: 4rpx;
  color: #7e5f39;
  font-size: 20rpx;
  line-height: 25rpx;
}

.trade-resource-list {
  width: 334rpx;
  flex: 0 0 334rpx;
  display: flex;
  justify-content: flex-end;
  gap: 10rpx;
}

.trade-resource {
  height: 54rpx;
  min-width: 96rpx;
  padding: 0 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  border-radius: 28rpx;
  background: rgba(255, 249, 234, 0.96);
  box-shadow: 0 8rpx 18rpx rgba(77, 45, 19, 0.14);
}

.trade-resource-icon {
  font-size: 28rpx;
}

.trade-resource-value {
  color: #5f4020;
  font-size: 23rpx;
  font-weight: 800;
}

.trade-resource-plus {
  color: #c79c55;
  font-size: 24rpx;
  font-weight: 900;
}

.trade-study-stage {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 0;
  z-index: 2;
  height: 430rpx;
}

.trade-speech {
  position: absolute;
  z-index: 4;
  left: 16rpx;
  top: 92rpx;
  width: 340rpx;
  min-height: 156rpx;
  padding: 28rpx 30rpx;
  border: 4rpx solid rgba(216, 171, 110, 0.68);
  border-radius: 24rpx;
  background: rgba(255, 249, 236, 0.96);
  box-shadow: 0 12rpx 24rpx rgba(86, 51, 23, 0.16);
}

.trade-speech text {
  display: block;
  color: #4f351d;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 42rpx;
}

.trade-speech::after {
  content: "";
  position: absolute;
  right: -20rpx;
  bottom: 28rpx;
  width: 38rpx;
  height: 38rpx;
  background: rgba(255, 249, 236, 0.96);
  border-right: 4rpx solid rgba(216, 171, 110, 0.68);
  border-bottom: 4rpx solid rgba(216, 171, 110, 0.68);
  transform: rotate(-18deg);
}

.trade-cat-image {
  position: absolute;
  right: 86rpx;
  bottom: 52rpx;
  z-index: 3;
  width: 356rpx;
  height: 356rpx;
  filter: drop-shadow(0 18rpx 20rpx rgba(70, 43, 22, 0.22));
}

.trade-nameplate {
  position: absolute;
  z-index: 4;
  right: 80rpx;
  bottom: 26rpx;
  width: 206rpx;
  padding: 12rpx 16rpx;
  border: 3rpx solid #c89455;
  border-radius: 8rpx;
  background: rgba(255, 241, 213, 0.95);
  text-align: center;
}

.trade-name,
.trade-role {
  display: block;
}

.trade-name {
  font-size: 25rpx;
  font-weight: 900;
}

.trade-role {
  margin-top: 2rpx;
  color: #805f3a;
  font-size: 19rpx;
}

.trade-panel {
  position: relative;
  z-index: 6;
  width: 704rpx;
  margin: -18rpx auto 0;
  padding: 0 20rpx 22rpx;
  border: 3rpx solid rgba(216, 181, 136, 0.7);
  border-radius: 26rpx;
  background: rgba(255, 248, 237, 0.98);
  box-shadow: 0 16rpx 36rpx rgba(102, 61, 25, 0.12);
}

.trade-industry-tabs {
  height: 82rpx;
  margin: 0 -20rpx;
  display: flex;
  overflow: hidden;
  border-radius: 24rpx 24rpx 0 0;
  background: #f4e3ca;
}

.trade-industry-tab {
  min-width: 176rpx;
  height: 82rpx;
  padding: 0 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  color: #9d825f;
  font-size: 25rpx;
  font-weight: 800;
}

.trade-industry-tab-active {
  position: relative;
  color: #df5e4f;
  background: #fff8ed;
}

.trade-industry-tab-active::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 74rpx;
  height: 5rpx;
  border-radius: 6rpx;
  background: #ee7869;
  transform: translateX(-50%);
}

.trade-industry-icon {
  font-size: 27rpx;
}

.trade-section-title {
  margin-top: 26rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #5b391d;
  font-size: 28rpx;
  font-weight: 900;
}

.trade-section-icon {
  font-size: 30rpx;
}

.trade-overview-grid {
  margin-top: 18rpx;
  display: flex;
  gap: 14rpx;
}

.trade-overview-card {
  width: 208rpx;
  min-height: 176rpx;
  padding: 18rpx 16rpx;
  border: 2rpx solid rgba(232, 203, 166, 0.78);
  border-radius: 16rpx;
  background: #fff5e7;
  box-shadow: 0 8rpx 18rpx rgba(111, 70, 31, 0.06);
}

.trade-card-label {
  display: block;
  color: #7a5a35;
  font-size: 22rpx;
  font-weight: 800;
}

.trade-card-main {
  display: block;
  margin-top: 18rpx;
  color: #e86152;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 44rpx;
}

.trade-card-sub {
  display: block;
  margin-top: 6rpx;
  color: #b89463;
  font-size: 18rpx;
}

.trade-card-chart {
  height: 62rpx;
  margin-top: 10rpx;
  display: flex;
  align-items: flex-end;
  gap: 8rpx;
}

.trade-chart-bar {
  width: 20rpx;
  border-radius: 10rpx 10rpx 0 0;
  background: linear-gradient(180deg, #ee8275, #f7c9bc);
}

.trade-feature-card {
  width: 230rpx;
}

.trade-feature-list {
  margin-top: 12rpx;
}

.trade-feature {
  display: block;
  color: #775738;
  font-size: 18rpx;
  line-height: 30rpx;
}

.trade-heat-card {
  background: #f8ead6;
}

.trade-heat-value {
  display: block;
  margin-top: 18rpx;
  color: #e86152;
  font-size: 48rpx;
  font-weight: 900;
  line-height: 56rpx;
}

.trade-heat-track {
  height: 12rpx;
  margin-top: 16rpx;
  overflow: hidden;
  border-radius: 12rpx;
  background: #f4ccb7;
}

.trade-heat-fill {
  height: 12rpx;
  border-radius: 12rpx;
  background: linear-gradient(90deg, #e95f54, #f2a06d);
}

.trade-heat-scale {
  margin-top: 8rpx;
  display: flex;
  justify-content: space-between;
  color: #ab906a;
  font-size: 16rpx;
}

.trade-list-card {
  margin-top: 22rpx;
  overflow: hidden;
  border: 2rpx solid rgba(232, 203, 166, 0.8);
  border-radius: 18rpx;
  background: #fffaf3;
  box-shadow: 0 10rpx 22rpx rgba(111, 70, 31, 0.08);
}

.trade-tabs {
  height: 76rpx;
  display: flex;
  background: #f4e4ce;
}

.trade-tab {
  position: relative;
  flex: 1;
  height: 76rpx;
  margin: 0;
  padding: 0;
  background: transparent;
  color: #8d7350;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 76rpx;
}

.trade-tab-active {
  color: #5f3a1e;
  background: #fffaf3;
}

.trade-tab-active::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 54rpx;
  height: 5rpx;
  border-radius: 6rpx;
  background: #ee7869;
  transform: translateX(-50%);
}

.trade-list-head {
  height: 58rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  color: #a78b66;
  font-size: 18rpx;
  border-bottom: 2rpx solid #f1dfc6;
}

.trade-list-head text:nth-child(1) {
  width: 228rpx;
}

.trade-list-head text:nth-child(2) {
  width: 118rpx;
}

.trade-list-head text:nth-child(3) {
  width: 160rpx;
}

.trade-list-head text:nth-child(4) {
  flex: 1;
  text-align: right;
}

.trade-list {
  padding: 0 18rpx;
}

.trade-list-row {
  min-height: 116rpx;
  padding: 18rpx 0;
  display: flex;
  align-items: center;
  border-bottom: 2rpx solid rgba(242, 224, 200, 0.72);
}

.trade-item-main {
  width: 228rpx;
  min-width: 0;
}

.trade-item-name {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #3f2d1d;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 32rpx;
}

.trade-item-code {
  display: block;
  margin-top: 8rpx;
  color: #9e8668;
  font-size: 19rpx;
}

.trade-price-box {
  width: 118rpx;
}

.trade-price {
  display: block;
  color: #e86152;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 30rpx;
}

.trade-change {
  display: block;
  margin-top: 5rpx;
  color: #e86152;
  font-size: 18rpx;
}

.trade-trend {
  width: 160rpx;
  height: 58rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 5rpx;
  border-bottom: 2rpx solid rgba(238, 130, 117, 0.25);
}

.trade-trend-dot {
  width: 7rpx;
  min-height: 8rpx;
  border-radius: 7rpx 7rpx 0 0;
  background: linear-gradient(180deg, #ed756a, #f7c5bd);
}

.trade-row-action {
  flex: 1;
  height: 50rpx;
  margin: 0;
  padding: 0 10rpx;
  border: 2rpx solid rgba(230, 160, 105, 0.72);
  border-radius: 26rpx;
  background: #fff8ef;
  color: #865e32;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 50rpx;
}

.trade-more-button {
  width: 260rpx;
  height: 62rpx;
  margin: 12rpx auto 14rpx;
  padding: 0;
  background: transparent;
  color: #ad8a56;
  font-size: 22rpx;
  line-height: 62rpx;
}

.trade-tip-card {
  margin-top: 22rpx;
  padding: 24rpx 26rpx;
  border-radius: 18rpx;
  background: #fff1df;
  box-shadow: inset 0 0 0 2rpx rgba(235, 205, 170, 0.55);
}

.trade-tip-title {
  color: #5c3b20;
  font-size: 25rpx;
  font-weight: 900;
}

.trade-tip-copy {
  display: block;
  margin-top: 12rpx;
  color: #6f5032;
  font-size: 23rpx;
  line-height: 38rpx;
}

.trade-actions {
  margin-top: 20rpx;
  display: flex;
  gap: 22rpx;
}

.trade-switch-button,
.trade-continue-button {
  height: 96rpx;
  margin: 0;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  border-radius: 50rpx;
  color: #5a3b1b;
}

.trade-switch-button {
  width: 292rpx;
  border: 3rpx solid rgba(162, 148, 83, 0.7);
  background: #f3efcd;
}

.trade-continue-button {
  flex: 1;
  border: 3rpx solid #d19436;
  background: linear-gradient(180deg, #ffe59a, #f1ad41);
  box-shadow: 0 8rpx 16rpx rgba(162, 94, 18, 0.22);
}

.trade-action-icon {
  font-size: 33rpx;
}

.trade-action-copy {
  min-width: 0;
}

.trade-action-title,
.trade-action-subtitle {
  display: block;
}

.trade-action-title {
  font-size: 28rpx;
  font-weight: 900;
  line-height: 34rpx;
}

.trade-action-subtitle {
  margin-top: 4rpx;
  color: #74512c;
  font-size: 18rpx;
  line-height: 24rpx;
}

.trade-action-arrow {
  margin-left: 4rpx;
  color: #9c6623;
  font-size: 42rpx;
  font-weight: 900;
}

.trade-risk-tip {
  display: block;
  margin-top: 18rpx;
  text-align: center;
  color: #b2966e;
  font-size: 20rpx;
}
