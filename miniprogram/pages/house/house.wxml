<view class="house-page">
  <scroll-view
    class="house-scroll"
    scroll-x
    scroll-left="{{sceneScrollLeft}}"
    enhanced
    bounces="{{false}}"
    show-scrollbar="{{false}}"
  >
    <view class="scene" style="{{sceneWidthStyle}}">
      <image class="scene-bg" src="/assets/room-portrait-v14-demo.jpg" mode="scaleToFill" />
      <view class="scene-vignette"></view>

      <view class="profile-card">
        <image src="/assets/cat-avatar-v6-demo.jpg" mode="aspectFit" />
        <view>
          <text class="name">小橘</text>
          <text class="level">Lv.12</text>
          <view class="progress"><view></view><text>80/170</text></view>
        </view>
      </view>

      <view class="top-hud">
        <view><text class="hud-icon">花</text><text>1280</text><text class="plus">+</text></view>
        <view><text class="hud-icon">草</text><text>36</text><text class="plus">+</text></view>
        <view><text class="hud-icon">罐</text><text>5</text><text class="plus">+</text></view>
      </view>

      <cat-agent
        x="{{cat.x}}"
        y="{{cat.y}}"
        mood="{{cat.mood}}"
        bubble="{{cat.bubble}}"
        sprite="{{cat.sprite}}"
        move-ms="{{cat.moveMs}}"
        dir="{{cat.dir}}"
        bind:catTap="openCat"
      />

      <block wx:for="{{hotspots}}" wx:key="id">
        <view
          class="house-hotspot"
          style="left: {{item.x}}%; top: {{item.y}}%; width: {{item.w}}%; height: {{item.h}}%;"
          data-target="{{item.target}}"
          data-id="{{item.id}}"
          bindtap="onHotspotTap"
        ></view>
      </block>
    </view>
  </scroll-view>
</view>
