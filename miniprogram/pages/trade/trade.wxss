  font-size: 26rpx;
  font-weight: 900;
}

.trade-success-cheer {
  margin-top: 18rpx;
  padding: 18rpx 22rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  border-radius: 22rpx;
  background: #fff1f3;
}

.trade-success-cheer image {
  width: 110rpx;
  height: 110rpx;
  flex: 0 0 110rpx;
}

.trade-success-cheer view {
  min-width: 0;
  flex: 1;
}

.trade-success-cheer text {
  display: block;
  color: #765548;
  font-size: 21rpx;
  line-height: 32rpx;
}

.trade-success-cheer text:first-child {
  color: #e05278;
  font-size: 24rpx;
  font-weight: 900;
}

.trade-holding-tools text::before {
  display: block;
  margin-bottom: 8rpx;
  color: #e05278;
  font-size: 34rpx;
}

.trade-holding-tools text:nth-child(1)::before {
  content: "💼";
}

.trade-holding-tools text:nth-child(2)::before {
  content: "◔";
}

.trade-holding-tools text:nth-child(3)::before {
  content: "▣";
}

.trade-holding-tools text:nth-child(4)::before {
  content: "☆";
}

.trade-advisor-list {
  gap: 14rpx;
}

.trade-advisor-card {
  min-height: 196rpx;
  padding: 12rpx 8rpx 14rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, #fff7fa, #fff);
  box-shadow: inset 0 0 0 2rpx rgba(250, 228, 235, 0.8);
}

.trade-advisor-card-active {
  background: #fff0f5;
  box-shadow:
    inset 0 0 0 3rpx rgba(242, 99, 136, 0.34),
    0 8rpx 18rpx rgba(218, 101, 132, 0.12);
}

.trade-advisor-avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 20rpx;
  object-position: center center;
}

.trade-advisor-name {
  margin-top: 8rpx;
  font-size: 19rpx;
  line-height: 25rpx;
}

.trade-advisor-role {
  margin-top: 2rpx;
  height: 24rpx;
  overflow: hidden;
  font-size: 16rpx;
  line-height: 24rpx;
  white-space: nowrap;
}

.trade-advisor-vote {
  height: 46rpx;
  margin-top: 6rpx;
  display: -webkit-box;
  overflow: hidden;
  color: #e05278;
  font-size: 17rpx;
  line-height: 23rpx;
  white-space: normal;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.trade-advisor-detail {
  margin-top: 16rpx;
  padding: 18rpx;
  display: flex;
  gap: 16rpx;
  border-radius: 20rpx;
  background: #fff8fb;
  box-shadow: inset 0 0 0 2rpx rgba(247, 220, 229, 0.86);
}

.trade-advisor-detail-avatar {
  width: 118rpx;
  height: 118rpx;
  flex: 0 0 118rpx;
  border-radius: 22rpx;
  background: #ffe8ef;
}

.trade-advisor-detail-copy {
  min-width: 0;
  flex: 1;
}

.trade-advisor-detail-headline {
  display: flex;
  justify-content: space-between;
  gap: 14rpx;
}

.trade-advisor-detail-headline text {
  color: #4b3329;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 31rpx;
}

.trade-advisor-detail-headline text:last-child {
  flex: 0 0 auto;
  color: #e05278;
  font-size: 19rpx;
}

.trade-advisor-detail-role,
.trade-advisor-detail-reason {
  display: block;
}

.trade-advisor-detail-role {
  margin-top: 6rpx;
  color: #9b7968;
  font-size: 19rpx;
  font-weight: 900;
  line-height: 28rpx;
}

.trade-advisor-detail-reason {
  margin-top: 8rpx;
  color: #6c5145;
  font-size: 20rpx;
  line-height: 31rpx;
}

.trade-advisor-result {
  align-items: flex-start;
  flex-wrap: wrap;
}

.trade-advisor-result text:last-child {
  flex-basis: 100%;
  white-space: normal;
  line-height: 28rpx;
}

.trade-success-hero {
  height: 390rpx;
}

.trade-success-cat {
  width: 640rpx;
  height: 366rpx;
}

.trade-success-cheer {
  padding: 20rpx 24rpx;
}

.trade-success-cheer::before {
  content: "🌱";
  width: 64rpx;
  height: 64rpx;
  flex: 0 0 64rpx;
  border-radius: 18rpx;
  background: #ffe2ea;
  color: #e05278;
  font-size: 34rpx;
  line-height: 64rpx;
  text-align: center;
}

.trade-success-cheer image {
  display: none;
}

.trade-success-summary-card text:last-child {
  white-space: normal;
}
