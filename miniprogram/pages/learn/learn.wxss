  border-radius: 34rpx;
  background: rgba(255, 249, 235, 0.9);
  color: #6a4f3e;
  box-shadow: 0 8rpx 18rpx rgba(72, 58, 37, 0.15);
}

.learn-tree-canvas-zooming {
  animation: learnTreeReveal 600ms cubic-bezier(0.2, 0.86, 0.24, 1);
  transform-origin: 50% 42%;
}

.learn-tree-canvas-zooming::after {
  content: "";
  position: absolute;
  inset: 0;
  z-index: 7;
  pointer-events: none;
  background:
    radial-gradient(circle at 52% 40%, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.18) 36%, rgba(255, 255, 255, 0.58) 76%),
    linear-gradient(90deg, rgba(255, 255, 255, 0.45), rgba(255, 255, 255, 0) 42%, rgba(255, 255, 255, 0.42));
  animation: learnCloudFade 600ms ease-out forwards;
}

@keyframes learnTreeReveal {
  0% {
    transform: scale(0.86) translateY(48rpx);
    filter: blur(8rpx) saturate(0.9);
  }
  62% {
    transform: scale(1.035) translateY(-10rpx);
    filter: blur(1rpx) saturate(1.05);
  }
  100% {
    transform: scale(1) translateY(0);
    filter: blur(0) saturate(1);
  }
}

@keyframes learnCloudFade {
  0% {
    opacity: 0.95;
  }
  100% {
    opacity: 0;
  }
}

