.learn-page {
  box-sizing: border-box;
  width: 750rpx;
  min-height: 100vh;
  overflow-x: hidden;
  padding-bottom: 34rpx;
  color: #553719;
  background: linear-gradient(180deg, #c59258 0%, #efd0a5 44%, #fff1d7 100%);
}

.learn-hero {
  position: relative;
  width: 750rpx;
  height: 690rpx;
  overflow: hidden;
}

.learn-room-bg {
  position: absolute;
  inset: 0;
  width: 750rpx;
  height: 690rpx;
  object-position: center 42%;
}

.learn-hero-mask {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(92, 55, 23, 0.34), rgba(255, 224, 177, 0.08) 48%, rgba(195, 133, 72, 0.14)),
    radial-gradient(circle at 74% 18%, rgba(255, 246, 211, 0.42), transparent 32%);
}

.learn-nav {
  position: relative;
  z-index: 2;
  padding: 72rpx 24rpx 0;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.learn-title-row {
  min-width: 0;
  flex: 1;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.learn-back {
  box-sizing: border-box;
  width: 70rpx;
  height: 70rpx;
  flex: 0 0 70rpx;
  padding: 0;
  border: 0;
  border-radius: 50%;
  background: rgba(255, 248, 234, 0.96);
  color: #8a5a27;
  font-size: 54rpx;
  font-weight: 700;
  line-height: 62rpx;
  box-shadow: 0 8rpx 18rpx rgba(81, 47, 19, 0.18);
}

.learn-back::after,
.learn-sector-card::after,
.learn-video-pill::after,
.learn-video-social button::after,
.learn-subject-badge::after,
.learn-map-nav button::after,
.learn-tree-nav button::after,
.learn-tree-node::after,
.learn-node-card button::after,
.learn-random-button::after,
.learn-start-button::after {
  border: 0;
}

.learn-title-copy {
  min-width: 0;
  padding-top: 2rpx;
  overflow: hidden;
}

.learn-title {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #fff9ef;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 40rpx;
  text-shadow: 0 3rpx 10rpx rgba(72, 42, 18, 0.42);
}

.learn-subtitle {
  display: block;
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: rgba(255, 250, 239, 0.95);
  font-size: 20rpx;
  line-height: 24rpx;
  text-shadow: 0 2rpx 7rpx rgba(72, 42, 18, 0.32);
}

.learn-resource-list {
  width: 292rpx;
  flex: 0 0 292rpx;
  display: flex;
  justify-content: flex-end;
  gap: 10rpx;
}

.learn-resource {
  height: 50rpx;
  min-width: 84rpx;
  padding: 0 7rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  border-radius: 28rpx;
  background: rgba(255, 249, 234, 0.96);
  box-shadow: 0 8rpx 18rpx rgba(77, 45, 19, 0.16);
}

.learn-resource-icon {
  font-size: 25rpx;
  line-height: 30rpx;
}

.learn-resource-value {
  color: #5f4020;
  font-size: 21rpx;
  font-weight: 800;
}

.learn-resource-plus {
  color: #c79c55;
  font-size: 22rpx;
  font-weight: 900;
}

.learn-study-stage {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 500rpx;
  z-index: 1;
  pointer-events: none;
}

.learn-speech {
  position: absolute;
  left: 38rpx;
  top: 112rpx;
  z-index: 4;
  width: 300rpx;
  min-height: 108rpx;
  padding: 22rpx 24rpx;
  border: 4rpx solid rgba(216, 171, 110, 0.68);
  border-radius: 22rpx;
  background: rgba(255, 249, 236, 0.96);
  box-shadow: 0 12rpx 24rpx rgba(86, 51, 23, 0.18);
}

.learn-speech text {
  display: block;
  color: #4f351d;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 36rpx;
}

.learn-speech::after {
  content: "";
  position: absolute;
  right: -14rpx;
  bottom: 24rpx;
  width: 28rpx;
  height: 28rpx;
  background: rgba(255, 249, 236, 0.96);
  border-right: 4rpx solid rgba(216, 171, 110, 0.68);
  border-bottom: 4rpx solid rgba(216, 171, 110, 0.68);
  transform: rotate(-18deg);
}

.learn-desk-shadow {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 132rpx;
  opacity: 0.6;
  border-radius: 0;
  background:
    linear-gradient(90deg, rgba(112, 72, 34, 0.18) 1rpx, transparent 1rpx) 0 0 / 88rpx 100%,
    linear-gradient(180deg, rgba(255, 236, 199, 0.6), rgba(145, 87, 42, 0.26));
  box-shadow: inset 0 16rpx 40rpx rgba(255, 244, 218, 0.22);
}

.learn-nameplate {
  position: absolute;
  z-index: 4;
  right: 58rpx;
  bottom: 12rpx;
  width: 214rpx;
  height: 76rpx;
  padding: 12rpx 18rpx 10rpx;
  border: 4rpx solid #b97832;
  border-radius: 10rpx 10rpx 6rpx 6rpx;
  background: linear-gradient(180deg, #fff6dc 0%, #f4d39a 100%);
  text-align: center;
  box-shadow:
    0 10rpx 0 rgba(126, 76, 29, 0.24),
    0 16rpx 22rpx rgba(75, 42, 16, 0.22),
    inset 0 0 0 2rpx rgba(255, 255, 255, 0.42);
  transform: perspective(180rpx) rotateX(5deg);
}

.learn-nameplate::before {
  content: "";
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  bottom: -12rpx;
  height: 8rpx;
  border-radius: 50%;
  background: rgba(92, 54, 20, 0.24);
}

.learn-name,
.learn-role {
  display: block;
}

.learn-name {
  color: #57320f;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 32rpx;
}

.learn-role {
  margin-top: 3rpx;
  color: #875b28;
  font-size: 19rpx;
  font-weight: 800;
  line-height: 25rpx;
}

.learn-panel {
  position: relative;
  z-index: 5;
  width: 704rpx;
  margin: -14rpx auto 0;
  padding: 28rpx 22rpx 24rpx;
  border: 3rpx solid rgba(205, 159, 99, 0.62);
  border-radius: 34rpx;
  background: rgba(255, 246, 231, 0.98);
  box-shadow: 0 16rpx 36rpx rgba(105, 64, 28, 0.16);
}

.learn-panel-title-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.learn-deco {
  color: #c5a05d;
  font-size: 24rpx;
  font-weight: 800;
}

.learn-panel-title {
  color: #6a431e;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 44rpx;
}

.learn-panel-subtitle {
  display: block;
  margin-top: 8rpx;
  text-align: center;
  color: #7b5a35;
  font-size: 22rpx;
  line-height: 32rpx;
}

.learn-market-map {
  margin-top: 18rpx;
  padding: 14rpx 16rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  border-radius: 20rpx;
  background: #fffaf0;
  box-shadow: inset 0 0 0 2rpx rgba(216, 171, 110, 0.34);
}

.learn-market-map view {
  min-width: 0;
  flex: 1;
  padding: 12rpx 12rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.82);
  text-align: center;
}

.learn-market-label,
.learn-market-value {
  display: block;
}

.learn-market-label {
  color: #a07b4e;
  font-size: 18rpx;
  font-weight: 800;
  line-height: 24rpx;
}

.learn-market-value {
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #58391d;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 34rpx;
}

.learn-market-arrow {
  color: #c48b35;
  font-size: 30rpx;
  font-weight: 900;
}

.learn-sector-grid {
  margin-top: 20rpx;
}

.learn-sector-row {
  display: flex;
  justify-content: center;
  gap: 14rpx;
}

.learn-sector-row + .learn-sector-row {
  margin-top: 20rpx;
}

.learn-sector-card {
  box-sizing: border-box;
  width: 154rpx;
  min-height: 220rpx;
  margin: 0;
  padding: 14rpx 10rpx 12rpx;
  border: 3rpx solid rgba(204, 161, 104, 0.5);
  border-radius: 22rpx;
  background: linear-gradient(180deg, #fffaf0, #fff1d8);
  color: #573719;
  text-align: center;
  box-shadow: 0 10rpx 22rpx rgba(103, 65, 29, 0.1);
}

.learn-sector-card-active {
  border-color: #e69c3f;
  background: linear-gradient(180deg, #fff4cc, #ffe0a8);
  box-shadow: 0 14rpx 26rpx rgba(181, 103, 28, 0.24);
}

.learn-sector-image {
  display: block;
  width: 126rpx;
  height: 110rpx;
  margin: 0 auto 10rpx;
  border-radius: 24rpx;
  background: #fff8e9;
  box-shadow: inset 0 0 0 2rpx rgba(210, 166, 101, 0.14);
}

.learn-sector-name {
  display: block;
  color: #4f331a;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 34rpx;
}

.learn-sector-desc {
  display: block;
  margin-top: 7rpx;
  color: #705234;
  font-size: 18rpx;
  font-weight: 600;
  line-height: 26rpx;
}

.learn-actions {
  margin-top: 28rpx;
  display: flex;
  gap: 24rpx;
}

.learn-random-button,
.learn-start-button {
  box-sizing: border-box;
  height: 96rpx;
  margin: 0;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  border-radius: 50rpx;
  color: #5a3b1b;
}

.learn-random-button {
  width: 300rpx;
  border: 3rpx solid rgba(162, 148, 83, 0.7);
  background: #f3efcd;
}

.learn-start-button {
  flex: 1;
  border: 3rpx solid #d19436;
  background: linear-gradient(180deg, #ffe59a, #f1ad41);
  box-shadow: 0 8rpx 16rpx rgba(162, 94, 18, 0.24);
}

.learn-button-icon {
  font-size: 34rpx;
}

.learn-button-copy {
  min-width: 0;
}

.learn-button-title,
.learn-button-subtitle {
  display: block;
}

.learn-button-title {
  font-size: 28rpx;
  font-weight: 900;
  line-height: 34rpx;
}

.learn-button-subtitle {
  margin-top: 4rpx;
  color: #74512c;
  font-size: 18rpx;
  line-height: 24rpx;
}

.learn-button-arrow {
  margin-left: 8rpx;
  color: #9c6623;
  font-size: 42rpx;
  font-weight: 900;
}

.learn-risk {
  margin-top: 14rpx;
  text-align: center;
}

.learn-risk text {
  display: block;
  color: #b2966e;
  font-size: 18rpx;
  line-height: 28rpx;
}

.learn-video-page,
.learn-island-page,
.learn-tree-page {
  position: relative;
  width: 750rpx;
  min-height: 100vh;
  overflow: hidden;
  color: #fff;
  background: #f7efe5;
}

.learn-video-page {
  background: #24150d;
}

.learn-island-page {
  background: #78c8df;
}

.learn-tree-page {
  background: #dfe9cb;
}

.learn-beauty-tree-page {
  background: #f8dfe8;
}

.learn-video-bg,
.learn-map-bg,
.learn-tree-bg,
.learn-video-shade,
.learn-map-shade,
.learn-tree-shade {
  position: absolute;
  inset: 0;
  width: 750rpx;
  height: 100%;
  min-height: 100vh;
}

.learn-video-shade {
  background:
    linear-gradient(180deg, rgba(28, 18, 10, 0.46) 0%, rgba(35, 20, 9, 0.04) 34%, rgba(25, 14, 8, 0.9) 100%),
    linear-gradient(90deg, rgba(22, 12, 5, 0.18), rgba(22, 12, 5, 0));
}

.learn-map-shade {
  background: linear-gradient(180deg, rgba(21, 92, 119, 0.18) 0%, rgba(21, 92, 119, 0.02) 42%, rgba(8, 65, 83, 0.4) 100%);
}

.learn-tree-shade {
  background: linear-gradient(180deg, rgba(255, 248, 230, 0.12), rgba(255, 248, 230, 0) 40%, rgba(29, 72, 45, 0.42) 100%);
}

.learn-beauty-tree-page .learn-tree-shade {
  background:
    radial-gradient(circle at 52% 22%, rgba(255, 255, 255, 0.42), transparent 30%),
    linear-gradient(180deg, rgba(255, 238, 245, 0.18), rgba(255, 238, 245, 0.02) 44%, rgba(128, 52, 72, 0.34) 100%);
}

.learn-video-top {
  position: relative;
  z-index: 2;
  padding: 48rpx 24rpx 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.learn-video-pill {
  box-sizing: border-box;
  width: 142rpx;
  height: 68rpx;
  margin: 0;
  padding: 0 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border-radius: 34rpx;
  background: rgba(255, 248, 232, 0.9);
  color: #4f3326;
  font-size: 19rpx;
  font-weight: 900;
  line-height: 24rpx;
}

.learn-video-pill text {
  display: block;
}

.learn-video-arrow {
  font-size: 44rpx;
  line-height: 44rpx;
}

.learn-club {
  color: #6e4b12;
  font-size: 38rpx;
}

.learn-video-progress {
  width: 280rpx;
  text-align: center;
}

.learn-video-progress text {
  display: block;
  color: #fff7ee;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 34rpx;
  text-shadow: 0 3rpx 8rpx rgba(34, 20, 10, 0.42);
}

.learn-video-track {
  height: 8rpx;
  margin-top: 14rpx;
  border-radius: 6rpx;
  background: rgba(255, 255, 255, 0.42);
}

.learn-video-track view {
  height: 8rpx;
  border-radius: 6rpx;
  background: #f1789b;
}

.learn-video-copy {
  position: relative;
  z-index: 2;
  width: 510rpx;
  margin: 92rpx 0 0 42rpx;
}

.learn-video-tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 22rpx;
  background: rgba(85, 53, 38, 0.5);
  color: #ffe7ed;
  font-size: 20rpx;
  font-weight: 900;
}

.learn-video-title {
  display: block;
  margin-top: 18rpx;
  color: #fff;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 52rpx;
  text-shadow: 0 5rpx 12rpx rgba(33, 18, 8, 0.56);
}

.learn-video-social {
  position: absolute;
  z-index: 2;
  right: 24rpx;
  top: 388rpx;
  width: 82rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  color: #fff;
  font-size: 19rpx;
  font-weight: 900;
  text-shadow: 0 3rpx 8rpx rgba(27, 15, 8, 0.5);
}

.learn-video-social image {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  background: #fff7ee;
  box-shadow: 0 6rpx 14rpx rgba(20, 12, 8, 0.26);
}

.learn-video-social button {
  width: 78rpx;
  height: 38rpx;
  margin: -3rpx 0 6rpx;
  padding: 0;
  border-radius: 22rpx;
  background: #f26f94;
  color: #fff;
  font-size: 18rpx;
  font-weight: 900;
  line-height: 38rpx;
}

.learn-video-logic {
  position: absolute;
  z-index: 3;
  left: 36rpx;
  right: 128rpx;
  bottom: 308rpx;
  padding: 18rpx 22rpx;
  border-radius: 18rpx;
  background: rgba(255, 246, 232, 0.9);
  color: #6d492c;
  box-shadow: 0 8rpx 18rpx rgba(33, 18, 8, 0.18);
}

.learn-video-logic text {
  display: block;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 35rpx;
}

.learn-video-control {
  position: absolute;
  z-index: 3;
  left: 30rpx;
  right: 30rpx;
  bottom: 238rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  color: #fff;
  font-size: 22rpx;
  font-weight: 800;
}

.learn-play {
  width: 34rpx;
  height: 34rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  font-size: 20rpx;
  line-height: 30rpx;
  text-align: center;
}

.learn-play-track {
  flex: 1;
  height: 6rpx;
  border-radius: 4rpx;
  background: rgba(255, 255, 255, 0.42);
}

.learn-play-track view {
  width: 36%;
  height: 6rpx;
  border-radius: 4rpx;
  background: #ff87a6;
}

.learn-video-teacher {
  position: absolute;
  z-index: 3;
  left: 28rpx;
  right: 28rpx;
  bottom: 76rpx;
  padding: 16rpx 18rpx;
  display: flex;
  gap: 16rpx;
  border-radius: 20rpx;
  background: rgba(29, 17, 10, 0.62);
  box-shadow: 0 10rpx 24rpx rgba(12, 7, 4, 0.24);
  backdrop-filter: blur(8rpx);
}

.learn-video-teacher image {
  width: 68rpx;
  height: 68rpx;
  flex: 0 0 68rpx;
  border-radius: 50%;
  background: #fff6e8;
}

.learn-video-teacher view {
  min-width: 0;
  flex: 1;
}

.learn-teacher-name,
.learn-teacher-copy,
.learn-teacher-tags {
  display: block;
}

.learn-teacher-name {
  color: #fff;
  font-size: 23rpx;
  font-weight: 900;
}

.learn-teacher-name text {
  margin-left: 8rpx;
  padding: 3rpx 10rpx;
  border-radius: 14rpx;
  background: #f46f95;
  font-size: 18rpx;
}

.learn-teacher-copy {
  margin-top: 7rpx;
  color: rgba(255, 255, 255, 0.92);
  font-size: 20rpx;
  line-height: 29rpx;
}

.learn-teacher-tags {
  margin-top: 7rpx;
  color: rgba(255, 244, 231, 0.92);
  font-size: 20rpx;
}

.learn-video-bottom {
  position: absolute;
  z-index: 3;
  left: 32rpx;
  right: 32rpx;
  bottom: 24rpx;
  display: flex;
  justify-content: space-between;
  color: rgba(255, 244, 230, 0.94);
  font-size: 19rpx;
  font-weight: 900;
}

.learn-video-bottom text {
  padding: 6rpx 12rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.14);
}

.learn-map-nav,
.learn-tree-nav {
  position: relative;
  z-index: 8;
  height: 104rpx;
  padding: 64rpx 26rpx 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.learn-map-nav button,
.learn-tree-nav button {
  width: 68rpx;
  height: 68rpx;
  min-width: 68rpx;
  max-width: 68rpx;
  margin: 0;
  padding: 0;
  border-radius: 50%;
  background: rgba(255, 249, 234, 0.96);
  color: #5a4136;
  font-size: 46rpx;
  font-weight: 900;
  line-height: 62rpx;
}

.learn-map-nav text {
  color: rgba(255, 255, 255, 0.92);
  font-size: 30rpx;
  font-weight: 900;
  text-shadow: 0 3rpx 8rpx rgba(31, 82, 103, 0.32);
}

.learn-map-scroll,
.learn-tree-scroll {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1;
  width: 750rpx;
  height: 100vh;
}

.learn-map-canvas,
.learn-tree-canvas {
  position: relative;
  width: 980rpx;
  height: 1760rpx;
  min-height: 1760rpx;
  overflow: hidden;
}

.learn-map-bg,
.learn-map-shade,
.learn-tree-bg,
.learn-tree-shade {
  width: 980rpx;
  height: 1760rpx;
  min-height: 1760rpx;
}

.learn-island-title {
  position: absolute;
  z-index: 3;
  left: 0;
  top: 166rpx;
  width: 750rpx;
  text-align: center;
}

.learn-island-title text {
  display: block;
  color: #1f6072;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 50rpx;
  text-shadow: 0 2rpx 8rpx rgba(255, 255, 255, 0.5);
}

.learn-island-title text:last-child {
  margin-top: 12rpx;
  color: #2b7784;
  font-size: 20rpx;
  line-height: 28rpx;
}

.learn-subject-badge {
  box-sizing: border-box;
  position: absolute;
  z-index: 4;
  width: 116rpx;
  height: 78rpx;
  margin: 0;
  padding: 0 10rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 28rpx;
  color: #fff;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 28rpx;
  text-align: center;
  box-shadow: 0 10rpx 18rpx rgba(31, 75, 72, 0.22);
}

.learn-subject-badge text {
  display: block;
}

.learn-subject-gold {
  background: rgba(221, 151, 57, 0.86);
}

.learn-subject-pink {
