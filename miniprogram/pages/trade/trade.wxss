.trade-page {
  box-sizing: border-box;
  width: 750rpx;
  min-height: 100vh;
  overflow-x: hidden;
  padding-bottom: 34rpx;
  color: #4f341c;
  background: linear-gradient(180deg, #e7bf88 0%, #fff0dc 46%, #fffaf4 100%);
}

.trade-hero {
  position: relative;
  width: 750rpx;
  height: 540rpx;
  overflow: hidden;
}

.trade-room-bg {
  position: absolute;
  inset: 0;
  width: 750rpx;
  height: 540rpx;
  object-position: center 42%;
}

.trade-hero-mask {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(255, 230, 191, 0.18), rgba(117, 71, 34, 0.03) 54%, rgba(230, 171, 105, 0.18)),
    radial-gradient(circle at 24% 23%, rgba(255, 247, 226, 0.34), transparent 34%);
}

.trade-nav {
  position: relative;
  z-index: 4;
  padding: 72rpx 24rpx 0;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
}

.trade-title-row {
  min-width: 0;
  flex: 1;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.trade-back,
.trade-flow-back,
.trade-help,
.trade-flow-help,
.trade-tab,
.trade-row-action,
.trade-more-button,
.trade-basket-mini,
.trade-checkout-button,
.trade-clear-basket,
.trade-cart-remove,
.trade-checkout-inline,
.trade-detail-secondary,
.trade-detail-primary,
.trade-confirm-buy,
.trade-switch-button,
.trade-continue-button {
  margin: 0;
  padding: 0;
}

.trade-back::after,
.trade-flow-back::after,
.trade-help::after,
.trade-flow-help::after,
.trade-tab::after,
.trade-row-action::after,
.trade-more-button::after,
.trade-basket-mini::after,
.trade-checkout-button::after,
.trade-clear-basket::after,
.trade-cart-remove::after,
.trade-checkout-inline::after,
.trade-detail-secondary::after,
.trade-detail-primary::after,
.trade-confirm-buy::after,
.trade-switch-button::after,
.trade-continue-button::after {
  border: 0;
}

.trade-back {
  box-sizing: border-box;
  width: 70rpx;
  height: 70rpx;
  min-width: 70rpx;
  max-width: 70rpx;
  flex: 0 0 70rpx;
  border: 0;
  border-radius: 50%;
  background: rgba(255, 249, 236, 0.96);
  color: #8a5a27;
  font-size: 54rpx;
  font-weight: 700;
  line-height: 62rpx;
  box-shadow: 0 8rpx 18rpx rgba(81, 47, 19, 0.16);
}

.trade-title-copy {
  min-width: 0;
}

.trade-heading-line {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.trade-title {
  max-width: 318rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #533115;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 40rpx;
  text-shadow: 0 3rpx 8rpx rgba(255, 241, 213, 0.52);
}

.trade-help {
  box-sizing: border-box;
  width: 38rpx;
  height: 38rpx;
  min-width: 38rpx;
  max-width: 38rpx;
  border-radius: 50%;
  background: rgba(255, 250, 236, 0.94);
  color: #ac834e;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 38rpx;
}

.trade-subtitle {
  display: block;
  margin-top: 5rpx;
  color: #785b36;
  font-size: 20rpx;
  line-height: 25rpx;
}

.trade-resource-list {
  width: 292rpx;
  flex: 0 0 292rpx;
  display: flex;
  justify-content: flex-end;
  gap: 10rpx;
}

.trade-basket-mini {
  box-sizing: border-box;
  position: absolute;
  right: 28rpx;
  top: 126rpx;
  z-index: 8;
  height: 44rpx;
  padding: 0 16rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  border: 2rpx solid rgba(247, 135, 161, 0.42);
  border-radius: 24rpx;
  background: rgba(255, 244, 247, 0.96);
  color: #ce466b;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 44rpx;
}

.trade-basket-mini-count {
  min-width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: #f35682;
  color: #fff;
  font-size: 18rpx;
  line-height: 28rpx;
  text-align: center;
}

.trade-resource {
  box-sizing: border-box;
  height: 50rpx;
  min-width: 84rpx;
  padding: 0 7rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  border-radius: 28rpx;
  background: rgba(255, 249, 234, 0.96);
  box-shadow: 0 8rpx 18rpx rgba(77, 45, 19, 0.14);
}

.trade-resource-icon {
  font-size: 25rpx;
}

.trade-resource-value {
  color: #5f4020;
  font-size: 21rpx;
  font-weight: 800;
}

.trade-resource-plus {
  color: #c79c55;
  font-size: 22rpx;
  font-weight: 900;
}

.trade-study-stage {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 2;
  height: 430rpx;
  pointer-events: none;
}

.trade-speech {
  position: absolute;
  z-index: 4;
  left: 38rpx;
  top: 116rpx;
  width: 300rpx;
  min-height: 112rpx;
  padding: 22rpx 24rpx;
  border: 4rpx solid rgba(216, 171, 110, 0.68);
  border-radius: 22rpx;
  background: rgba(255, 249, 236, 0.96);
  box-shadow: 0 12rpx 24rpx rgba(86, 51, 23, 0.16);
}

.trade-speech text {
  display: block;
  color: #4f351d;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 34rpx;
}

.trade-speech::after {
  content: "";
  position: absolute;
  right: -14rpx;
  bottom: 24rpx;
  width: 28rpx;
  height: 28rpx;
  background: rgba(255, 249, 236, 0.96);
  border-right: 4rpx solid rgba(216, 171, 110, 0.68);
  border-bottom: 4rpx solid rgba(216, 171, 110, 0.68);
  transform: rotate(-18deg);
}

.trade-nameplate {
  position: absolute;
  z-index: 4;
  right: 58rpx;
  bottom: 10rpx;
  width: 214rpx;
  height: 76rpx;
  padding: 12rpx 18rpx 10rpx;
  border: 4rpx solid #b97832;
  border-radius: 10rpx 10rpx 6rpx 6rpx;
  background: linear-gradient(180deg, #fff6dc 0%, #f4d39a 100%);
  text-align: center;
  box-shadow:
    0 10rpx 0 rgba(126, 76, 29, 0.24),
    0 16rpx 22rpx rgba(75, 42, 16, 0.22),
    inset 0 0 0 2rpx rgba(255, 255, 255, 0.42);
  transform: perspective(180rpx) rotateX(5deg);
}

.trade-nameplate::before {
  content: "";
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  bottom: -12rpx;
  height: 8rpx;
  border-radius: 50%;
  background: rgba(92, 54, 20, 0.24);
}

.trade-name,
.trade-role {
  display: block;
}

.trade-name {
  color: #57320f;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 32rpx;
}

.trade-role {
  margin-top: 3rpx;
  color: #875b28;
  font-size: 19rpx;
  font-weight: 800;
  line-height: 25rpx;
}

.trade-panel {
  position: relative;
  z-index: 6;
  width: 704rpx;
  margin: -18rpx auto 0;
  padding: 0 20rpx 22rpx;
  border: 3rpx solid rgba(216, 181, 136, 0.7);
  border-radius: 30rpx;
  background: rgba(255, 248, 237, 0.98);
  box-shadow: 0 16rpx 36rpx rgba(102, 61, 25, 0.12);
}

.trade-industry-tabs {
  height: 78rpx;
  margin: 0 -20rpx;
  display: flex;
  overflow: hidden;
  border-radius: 28rpx 28rpx 0 0;
  background: #f4e3ca;
}

.trade-industry-tab {
  box-sizing: border-box;
  flex: 1;
  min-width: 0;
  height: 78rpx;
  padding: 0 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  color: #9d825f;
  font-size: 26rpx;
  font-weight: 900;
}

.trade-industry-tab-active {
  position: relative;
  color: #df5e4f;
  background: #fff8ed;
}

.trade-industry-tab-active::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 74rpx;
  height: 5rpx;
  border-radius: 6rpx;
  background: #ee7869;
  transform: translateX(-50%);
}

.trade-industry-icon {
  font-size: 31rpx;
}

.trade-section-title {
  margin-top: 22rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #5b391d;
  font-size: 28rpx;
  font-weight: 900;
}

.trade-section-icon {
  font-size: 30rpx;
}

.trade-market-map {
  margin-top: 14rpx;
  padding: 14rpx 16rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  border: 2rpx solid rgba(234, 203, 163, 0.72);
  border-radius: 18rpx;
  background: #fff8ea;
}

.trade-market-node {
  min-width: 0;
  flex: 1;
  padding: 10rpx 8rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.72);
  text-align: center;
}

.trade-market-node text {
  display: block;
}

.trade-market-node text:first-child {
  color: #a3865d;
  font-size: 17rpx;
  font-weight: 800;
  line-height: 24rpx;
}

.trade-market-node text:last-child {
  margin-top: 3rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #4f351c;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 30rpx;
}

.trade-market-node-entry text:last-child {
  color: #df5e4f;
}

.trade-market-node-market {
  background: #fff0f4;
}

.trade-market-node-market text:last-child {
  color: #d84b73;
}

.trade-market-arrow {
  color: #c59c62;
  font-size: 30rpx;
  font-weight: 900;
}

.trade-overview-grid {
  margin-top: 16rpx;
  display: flex;
  gap: 14rpx;
}

.trade-overview-card {
  box-sizing: border-box;
  width: 198rpx;
  min-height: 168rpx;
  padding: 16rpx 15rpx;
  border: 2rpx solid rgba(232, 203, 166, 0.78);
  border-radius: 16rpx;
  background: #fff5e7;
  box-shadow: 0 8rpx 18rpx rgba(111, 70, 31, 0.06);
}

.trade-card-label {
  display: block;
  color: #7a5a35;
  font-size: 22rpx;
  font-weight: 800;
}

.trade-card-main {
  display: block;
  margin-top: 14rpx;
  color: #e86152;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 42rpx;
}

.trade-card-sub {
  display: block;
  margin-top: 6rpx;
  color: #b89463;
  font-size: 18rpx;
}

.trade-card-chart {
  height: 52rpx;
  margin-top: 8rpx;
  display: flex;
  align-items: flex-end;
  gap: 8rpx;
}

.trade-chart-bar {
  width: 20rpx;
  border-radius: 10rpx 10rpx 0 0;
  background: linear-gradient(180deg, #ee8275, #f7c9bc);
}

.trade-feature-card {
  width: 226rpx;
}

.trade-feature-list {
  margin-top: 10rpx;
}

.trade-feature {
  display: block;
  color: #775738;
  font-size: 18rpx;
  line-height: 27rpx;
}

.trade-heat-card {
  background: #f8ead6;
}

.trade-heat-value {
  display: block;
  margin-top: 14rpx;
  color: #e86152;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 52rpx;
}

.trade-heat-track {
  height: 12rpx;
  margin-top: 16rpx;
  overflow: hidden;
  border-radius: 12rpx;
  background: #f4ccb7;
}

.trade-heat-fill {
  height: 12rpx;
  border-radius: 12rpx;
  background: linear-gradient(90deg, #e95f54, #f2a06d);
}

.trade-heat-scale {
  margin-top: 8rpx;
  display: flex;
  justify-content: space-between;
  color: #ab906a;
  font-size: 16rpx;
}

.trade-list-card {
  margin-top: 20rpx;
  overflow: hidden;
  border: 2rpx solid rgba(232, 203, 166, 0.8);
  border-radius: 18rpx;
  background: #fffaf3;
  box-shadow: 0 10rpx 22rpx rgba(111, 70, 31, 0.08);
}

.trade-list-card-fund {
  border-color: rgba(248, 181, 195, 0.62);
  background: #fff9fb;
  box-shadow: 0 12rpx 26rpx rgba(204, 87, 118, 0.1);
}

.trade-category-strip {
  padding: 18rpx 14rpx 16rpx;
  display: flex;
  gap: 10rpx;
  background: #fff9fb;
}

.trade-category-chip {
  box-sizing: border-box;
  flex: 1;
  min-width: 0;
  height: 104rpx;
  padding: 10rpx 4rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border: 2rpx solid rgba(246, 202, 214, 0.6);
  border-radius: 16rpx;
  background: #fff;
  color: #9a7a68;
  font-size: 18rpx;
  font-weight: 900;
  text-align: center;
}

.trade-category-chip-active {
  border-color: rgba(242, 99, 136, 0.62);
  background: #fff0f5;
  color: #d84b73;
}

.trade-category-icon {
  font-size: 34rpx;
  line-height: 36rpx;
}

.trade-tabs {
  height: 70rpx;
  display: flex;
  background: #f4e4ce;
}

.trade-list-card-fund .trade-tabs {
  background: #ffe7ee;
}

.trade-tab {
  box-sizing: border-box;
  position: relative;
  flex: 1;
  height: 70rpx;
  background: transparent;
  color: #8d7350;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 70rpx;
}

.trade-tab-active {
  color: #5f3a1e;
  background: #fffaf3;
}

.trade-list-card-fund .trade-tab-active {
  color: #c94368;
  background: #fff9fb;
}

.trade-tab-active::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 54rpx;
  height: 5rpx;
  border-radius: 6rpx;
  background: #ee7869;
  transform: translateX(-50%);
}

.trade-list-card-fund .trade-tab-active::after {
  background: #f25a86;
}

.trade-list-head {
  height: 52rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  color: #a78b66;
  font-size: 18rpx;
  border-bottom: 2rpx solid #f1dfc6;
}

.trade-list-head text:nth-child(1) {
  width: 228rpx;
}

.trade-list-head text:nth-child(2) {
  width: 118rpx;
}

.trade-list-head text:nth-child(3) {
  width: 160rpx;
}

.trade-list-head text:nth-child(4) {
  flex: 1;
  text-align: right;
}

.trade-list-action-head {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
}

.trade-list-action-head text {
  width: auto;
}

.trade-filter-button {
  width: 36rpx;
  height: 36rpx;
  margin: 0;
  padding: 0;
  border-radius: 12rpx;
  background: #fff3f7;
  color: #d86f8a;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 34rpx;
}

.trade-filter-button::after {
  border: 0;
}

.trade-list {
  padding: 0 18rpx;
}

.trade-filter-pill {
  margin: 14rpx 18rpx 0;
  padding: 12rpx 16rpx;
  display: flex;
  justify-content: space-between;
  border-radius: 18rpx;
  background: #fff3f7;
  color: #b87586;
  font-size: 20rpx;
  font-weight: 900;
}

.trade-list-row {
  min-height: 108rpx;
  margin: 0 -4rpx;
  padding: 14rpx 4rpx;
  display: flex;
  align-items: center;
  border-bottom: 2rpx solid rgba(242, 224, 200, 0.72);
  background: linear-gradient(90deg, rgba(255, 250, 243, 0), rgba(255, 235, 231, 0.34), rgba(255, 250, 243, 0));
}

.trade-list-card-fund .trade-list-row {
  background: linear-gradient(90deg, rgba(255, 250, 252, 0), rgba(255, 233, 240, 0.52), rgba(255, 250, 252, 0));
}

.trade-item-main {
  width: 228rpx;
  min-width: 0;
}

.trade-item-name {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #3f2d1d;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 32rpx;
}

.trade-item-code {
  display: block;
  margin-top: 8rpx;
  color: #9e8668;
  font-size: 19rpx;
}

.trade-price-box {
  width: 118rpx;
}

.trade-price {
  display: block;
  color: #e86152;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 30rpx;
}

.trade-change {
  display: block;
  margin-top: 5rpx;
  color: #e86152;
  font-size: 18rpx;
}

.trade-trend {
  width: 160rpx;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx 12rpx 0 0;
  background: linear-gradient(180deg, rgba(244, 129, 143, 0.03), rgba(244, 129, 143, 0.1));
}

.trade-trend-image {
  width: 150rpx;
  height: 68rpx;
}

.trade-row-action {
  box-sizing: border-box;
  flex: 1;
  height: 48rpx;
  padding: 0 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  border: 2rpx solid rgba(230, 160, 105, 0.72);
  border-radius: 26rpx;
  background: #fff8ef;
  color: #d86f66;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 48rpx;
}

.trade-row-action-icon {
  font-size: 22rpx;
  line-height: 24rpx;
}

.trade-list-card-fund .trade-row-action {
  border-color: rgba(242, 99, 136, 0.38);
  background: #fff;
  color: #d94a72;
}

.trade-basket-card {
  position: sticky;
  bottom: 18rpx;
  z-index: 12;
  margin-top: 20rpx;
  padding: 16rpx 18rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  border: 2rpx solid rgba(248, 181, 195, 0.5);
  border-radius: 22rpx;
  background: linear-gradient(90deg, #fff4f1, #ffeef4);
  box-shadow: 0 10rpx 24rpx rgba(201, 85, 111, 0.1);
}

.trade-basket-cat {
  width: 82rpx;
  height: 82rpx;
  flex: 0 0 82rpx;
}

.trade-basket-copy {
  min-width: 0;
  flex: 1;
}

.trade-basket-title,
.trade-basket-subtitle {
  display: block;
}

.trade-basket-title {
  color: #4b3424;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 32rpx;
}

.trade-basket-subtitle {
  margin-top: 4rpx;
  color: #8f7253;
  font-size: 21rpx;
}

.trade-checkout-button {
  width: 180rpx;
  height: 66rpx;
  border-radius: 34rpx;
  background: linear-gradient(180deg, #ff6f95, #f23d73);
  color: #fff;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 66rpx;
}

.trade-more-button {
  width: 260rpx;
  height: 54rpx;
  margin: 8rpx auto 10rpx;
  background: transparent;
  color: #ad8a56;
  font-size: 22rpx;
  line-height: 54rpx;
}

.trade-tip-card {
  margin-top: 18rpx;
  padding: 20rpx 24rpx;
  border-radius: 18rpx;
  background: #fff1df;
  box-shadow: inset 0 0 0 2rpx rgba(235, 205, 170, 0.55);
}

.trade-tip-title {
  color: #5c3b20;
  font-size: 25rpx;
  font-weight: 900;
}

.trade-tip-copy {
  display: block;
  margin-top: 10rpx;
  color: #6f5032;
  font-size: 22rpx;
  line-height: 34rpx;
}

.trade-actions {
  margin-top: 18rpx;
  display: flex;
  gap: 22rpx;
}

.trade-switch-button,
.trade-continue-button {
  box-sizing: border-box;
  height: 88rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  border-radius: 50rpx;
  color: #5a3b1b;
}

.trade-switch-button {
  width: 292rpx;
  border: 3rpx solid rgba(162, 148, 83, 0.7);
  background: #f3efcd;
}

.trade-continue-button {
  flex: 1;
  border: 3rpx solid #d19436;
  background: linear-gradient(180deg, #ffe59a, #f1ad41);
  box-shadow: 0 8rpx 16rpx rgba(162, 94, 18, 0.22);
}

.trade-action-icon {
  font-size: 33rpx;
}

.trade-action-copy {
  min-width: 0;
}

.trade-action-title,
.trade-action-subtitle {
  display: block;
}

.trade-action-title {
  font-size: 28rpx;
  font-weight: 900;
  line-height: 34rpx;
}

.trade-action-subtitle {
