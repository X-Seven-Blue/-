<view class="trade-page" wx:if="{{sector}}">
  <view class="trade-hero">
    <image class="trade-room-bg" src="/assets/room-portrait-v10.png" mode="aspectFill" />
    <view class="trade-hero-mask"></view>

    <view class="trade-nav">
      <view class="trade-title-row">
        <button class="trade-back" bindtap="goBack" aria-label="返回">‹</button>
        <view class="trade-title-copy">
          <view class="trade-heading-line">
            <text class="trade-title">{{sector.name}}赛道研究中心</text>
            <button class="trade-help" bindtap="handleSwitchSector" aria-label="切换赛道">?</button>
          </view>
          <text class="trade-subtitle">ETF模拟交易 &gt; 赛道研究</text>
        </view>
      </view>
      <view class="trade-resource-list">
        <view class="trade-resource" wx:for="{{resources}}" wx:key="icon">
          <text class="trade-resource-icon">{{item.icon}}</text>
          <text class="trade-resource-value">{{item.value}}</text>
          <text class="trade-resource-plus">+</text>
        </view>
      </view>
    </view>

    <view class="trade-study-stage">
      <view class="trade-speech">
        <text>你已选择 {{sector.name}} 赛道</text>
        <text>{{sector.tradeFocus}}</text>
        <text>{{sector.tradeOpportunity}}</text>
      </view>
      <image class="trade-cat-image" src="/assets/cat-write.png" mode="aspectFit" />
      <view class="trade-nameplate">
        <text class="trade-name">查理·芒格</text>
        <text class="trade-role">喵学者</text>
      </view>
    </view>
  </view>

  <view class="trade-panel">
    <view class="trade-industry-tabs">
      <view
        class="trade-industry-tab {{sector.id === item.id ? 'trade-industry-tab-active' : ''}}"
        wx:for="{{sectors}}"
        wx:key="id"
      >
        <text class="trade-industry-icon">{{item.icon}}</text>
        <text>{{item.name}}行业</text>
      </view>
    </view>

    <view class="trade-section-title">
      <text class="trade-section-icon">🌱</text>
      <text>赛道概览</text>
    </view>

    <view class="trade-overview-grid">
      <view class="trade-overview-card">
        <text class="trade-card-label">行业景气度</text>
        <text class="trade-card-main">{{sector.prosperity}}</text>
        <text class="trade-card-sub">{{sector.prosperityHint}}</text>
        <view class="trade-card-chart">
          <view class="trade-chart-bar" style="height: 18rpx;"></view>
          <view class="trade-chart-bar" style="height: 30rpx;"></view>
          <view class="trade-chart-bar" style="height: 26rpx;"></view>
          <view class="trade-chart-bar" style="height: 42rpx;"></view>
          <view class="trade-chart-bar" style="height: 56rpx;"></view>
        </view>
      </view>

      <view class="trade-overview-card trade-feature-card">
        <text class="trade-card-label">行业特点</text>
        <view class="trade-feature-list">
          <text class="trade-feature" wx:for="{{sector.featurePoints}}" wx:key="*this">✓ {{item}}</text>
        </view>
      </view>

      <view class="trade-overview-card trade-heat-card">
        <text class="trade-card-label">赛道热度</text>
        <text class="trade-heat-value">{{overview.heat}}</text>
        <view class="trade-heat-track">
          <view class="trade-heat-fill" style="width: {{overview.heat}}%;"></view>
        </view>
        <view class="trade-heat-scale">
          <text>0</text>
          <text>50</text>
          <text>100</text>
        </view>
      </view>
    </view>

    <view class="trade-list-card">
      <view class="trade-tabs">
        <button
          class="trade-tab {{activeTab === item ? 'trade-tab-active' : ''}}"
          wx:for="{{tabs}}"
          wx:key="*this"
          data-tab="{{item}}"
          bindtap="switchTab"
        >{{item}}</button>
      </view>

      <view class="trade-list-head">
        <text>{{activeTab === '指数' ? '指数名称' : '基金名称'}}</text>
        <text>{{activeTab === '指数' ? '最新价' : '最新净值'}}</text>
        <text>近1年走势</text>
        <text>{{activeTab === '指数' ? '跟踪基金' : '操作'}}</text>
      </view>

      <view class="trade-list">
        <view class="trade-list-row" wx:for="{{displayItems}}" wx:key="id">
          <view class="trade-item-main">
            <text class="trade-item-name">{{item.name}}</text>
            <text class="trade-item-code">{{item.code}}</text>
          </view>
          <view class="trade-price-box">
            <text class="trade-price">{{item.latest}}</text>
            <text class="trade-change">{{item.changePercent}}</text>
          </view>
          <view class="trade-trend">
            <view
              class="trade-trend-dot"
              wx:for="{{item.trend}}"
              wx:for-item="point"
              wx:key="*this"
              style="height: {{point}}rpx;"
            ></view>
          </view>
          <button class="trade-row-action" data-id="{{item.id}}" bindtap="toggleFollow">
            {{activeTab === '指数' ? item.actionText : (item.followed ? '已关注' : '+ 关注')}}
          </button>
        </view>
      </view>

      <button class="trade-more-button">查看更多{{activeTab}} ›</button>
    </view>

    <view class="trade-tip-card">
      <view class="trade-tip-title">🧡 芒格小贴士</view>
      <text class="trade-tip-copy">投资的第一条原则是，永远不要亏钱；第二条原则是，永远不要忘记第一条。</text>
    </view>

    <view class="trade-actions">
      <button class="trade-switch-button" bindtap="handleSwitchSector">
        <text class="trade-action-icon">☘️</text>
        <view class="trade-action-copy">
          <text class="trade-action-title">换个赛道</text>
          <text class="trade-action-subtitle">重新选择研究领域</text>
        </view>
      </button>
      <button class="trade-continue-button">
        <text class="trade-action-icon">🐾</text>
        <view class="trade-action-copy">
          <text class="trade-action-title">继续研究</text>
          <text class="trade-action-subtitle">查看ETF和场外基金</text>
        </view>
        <text class="trade-action-arrow">→</text>
      </button>
    </view>
  </view>

  <text class="trade-risk-tip">数据仅供参考，不构成投资建议</text>
</view>
