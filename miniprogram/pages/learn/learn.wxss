.learn-page {
  box-sizing: border-box;
  width: 750rpx;
  min-height: 1334rpx;
  overflow-x: hidden;
  padding-bottom: 34rpx;
  color: #553719;
  background: linear-gradient(180deg, #c59258 0%, #efd0a5 44%, #fff1d7 100%);
}

.learn-hero {
  position: relative;
  width: 750rpx;
  height: 720rpx;
  overflow: hidden;
}

.learn-room-bg {
  position: absolute;
  inset: 0;
  width: 750rpx;
  height: 720rpx;
}

.learn-hero-mask {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(92, 55, 23, 0.34), rgba(255, 224, 177, 0.08) 48%, rgba(195, 133, 72, 0.14)),
    radial-gradient(circle at 74% 18%, rgba(255, 246, 211, 0.42), transparent 32%);
}

.learn-nav {
  position: relative;
  z-index: 2;
  padding: 72rpx 24rpx 0;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.learn-title-row {
  min-width: 0;
  flex: 1;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.learn-back {
  box-sizing: border-box;
  width: 70rpx;
  height: 70rpx;
  flex: 0 0 70rpx;
  padding: 0;
  border: 0;
  border-radius: 50%;
  background: rgba(255, 248, 234, 0.96);
  color: #8a5a27;
  font-size: 54rpx;
  font-weight: 700;
  line-height: 62rpx;
  box-shadow: 0 8rpx 18rpx rgba(81, 47, 19, 0.18);
}

.learn-back::after,
.learn-sector-card::after,
.learn-random-button::after,
.learn-start-button::after {
  border: 0;
}

.learn-title-copy {
  min-width: 0;
  padding-top: 2rpx;
  overflow: hidden;
}

.learn-title {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #fff9ef;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 40rpx;
  text-shadow: 0 3rpx 10rpx rgba(72, 42, 18, 0.42);
}

.learn-subtitle {
  display: block;
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: rgba(255, 250, 239, 0.95);
  font-size: 20rpx;
  line-height: 24rpx;
  text-shadow: 0 2rpx 7rpx rgba(72, 42, 18, 0.32);
}

.learn-resource-list {
  width: 292rpx;
  flex: 0 0 292rpx;
  display: flex;
  justify-content: flex-end;
  gap: 10rpx;
}

.learn-resource {
  height: 50rpx;
  min-width: 84rpx;
  padding: 0 7rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  border-radius: 28rpx;
  background: rgba(255, 249, 234, 0.96);
  box-shadow: 0 8rpx 18rpx rgba(77, 45, 19, 0.16);
}

.learn-resource-icon {
  font-size: 25rpx;
  line-height: 30rpx;
}

.learn-resource-value {
  color: #5f4020;
  font-size: 21rpx;
  font-weight: 800;
}

.learn-resource-plus {
  color: #c79c55;
  font-size: 22rpx;
  font-weight: 900;
}

.learn-study-stage {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 0;
  height: 520rpx;
  z-index: 1;
}

.learn-speech {
  position: absolute;
  left: 20rpx;
  top: 82rpx;
  z-index: 4;
  width: 386rpx;
  min-height: 148rpx;
  padding: 32rpx 34rpx;
  border: 4rpx solid rgba(216, 171, 110, 0.68);
  border-radius: 24rpx;
  background: rgba(255, 249, 236, 0.96);
  box-shadow: 0 12rpx 24rpx rgba(86, 51, 23, 0.18);
}

.learn-speech text {
  display: block;
  color: #4f351d;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 46rpx;
}

.learn-speech::after {
  content: "";
  position: absolute;
  right: -20rpx;
  bottom: 30rpx;
  width: 38rpx;
  height: 38rpx;
  background: rgba(255, 249, 236, 0.96);
  border-right: 4rpx solid rgba(216, 171, 110, 0.68);
  border-bottom: 4rpx solid rgba(216, 171, 110, 0.68);
  transform: rotate(-18deg);
}

.learn-desk-shadow {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 150rpx;
  opacity: 0.52;
  border-radius: 28rpx;
  background:
    linear-gradient(90deg, rgba(112, 72, 34, 0.18) 1rpx, transparent 1rpx) 0 0 / 88rpx 100%,
    linear-gradient(180deg, rgba(255, 236, 199, 0.6), rgba(145, 87, 42, 0.26));
  box-shadow: inset 0 16rpx 40rpx rgba(255, 244, 218, 0.22);
}

.learn-nameplate {
  position: absolute;
  z-index: 4;
  right: 74rpx;
  bottom: 30rpx;
  width: 210rpx;
  padding: 12rpx 16rpx;
  border: 3rpx solid #c89455;
  border-radius: 8rpx;
  background: rgba(255, 241, 213, 0.95);
  text-align: center;
  box-shadow: 0 8rpx 14rpx rgba(82, 51, 24, 0.16);
}

.learn-name,
.learn-role {
  display: block;
}

.learn-name {
  font-size: 25rpx;
  font-weight: 900;
}

.learn-role {
  margin-top: 2rpx;
  color: #805f3a;
  font-size: 19rpx;
}

.learn-panel {
  position: relative;
  z-index: 5;
  width: 704rpx;
  margin: -18rpx auto 0;
  padding: 32rpx 22rpx 24rpx;
  border: 3rpx solid rgba(205, 159, 99, 0.62);
  border-radius: 34rpx;
  background: rgba(255, 246, 231, 0.98);
  box-shadow: 0 16rpx 36rpx rgba(105, 64, 28, 0.16);
}

.learn-panel-title-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.learn-deco {
  color: #c5a05d;
  font-size: 24rpx;
  font-weight: 800;
}

.learn-panel-title {
  color: #6a431e;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 44rpx;
}

.learn-panel-subtitle {
  display: block;
  margin-top: 8rpx;
  text-align: center;
  color: #7b5a35;
  font-size: 22rpx;
  line-height: 32rpx;
}

.learn-sector-grid {
  margin-top: 24rpx;
}

.learn-sector-row {
  display: flex;
  justify-content: center;
  gap: 14rpx;
}

.learn-sector-row + .learn-sector-row {
  margin-top: 20rpx;
}

.learn-sector-card {
  box-sizing: border-box;
  width: 154rpx;
  min-height: 232rpx;
  margin: 0;
  padding: 16rpx 10rpx 14rpx;
  border: 3rpx solid rgba(204, 161, 104, 0.5);
  border-radius: 22rpx;
  background: linear-gradient(180deg, #fffaf0, #fff1d8);
  color: #573719;
  text-align: center;
  box-shadow: 0 10rpx 22rpx rgba(103, 65, 29, 0.1);
}

.learn-sector-card-active {
  border-color: #e69c3f;
  background: linear-gradient(180deg, #fff4cc, #ffe0a8);
  box-shadow: 0 14rpx 26rpx rgba(181, 103, 28, 0.24);
}

.learn-sector-image {
  display: block;
  width: 126rpx;
  height: 118rpx;
  margin: 0 auto 12rpx;
  border-radius: 24rpx;
  background: #fff8e9;
  box-shadow: inset 0 0 0 2rpx rgba(210, 166, 101, 0.14);
}

.learn-sector-name {
  display: block;
  color: #4f331a;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 34rpx;
}

.learn-sector-desc {
  display: block;
  margin-top: 7rpx;
  color: #705234;
  font-size: 18rpx;
  font-weight: 600;
  line-height: 26rpx;
}

.learn-actions {
  margin-top: 28rpx;
  display: flex;
  gap: 24rpx;
}

.learn-random-button,
.learn-start-button {
  box-sizing: border-box;
  height: 96rpx;
  margin: 0;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  border-radius: 50rpx;
  color: #5a3b1b;
}

.learn-random-button {
  width: 300rpx;
  border: 3rpx solid rgba(162, 148, 83, 0.7);
  background: #f3efcd;
}

.learn-start-button {
  flex: 1;
  border: 3rpx solid #d19436;
  background: linear-gradient(180deg, #ffe59a, #f1ad41);
  box-shadow: 0 8rpx 16rpx rgba(162, 94, 18, 0.24);
}

.learn-button-icon {
  font-size: 34rpx;
}

.learn-button-copy {
  min-width: 0;
}

.learn-button-title,
.learn-button-subtitle {
  display: block;
}

.learn-button-title {
  font-size: 28rpx;
  font-weight: 900;
  line-height: 34rpx;
}

.learn-button-subtitle {
  margin-top: 4rpx;
  color: #74512c;
  font-size: 18rpx;
  line-height: 24rpx;
}

.learn-button-arrow {
  margin-left: 8rpx;
  color: #9c6623;
  font-size: 42rpx;
  font-weight: 900;
}

.learn-risk {
  margin-top: 14rpx;
  text-align: center;
}

.learn-risk text {
  display: block;
  color: #b2966e;
  font-size: 18rpx;
  line-height: 28rpx;
}
