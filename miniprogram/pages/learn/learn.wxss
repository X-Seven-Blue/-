page {
  background: #f4d5aa;
}

.learn-page {
  min-height: 100vh;
  padding: 36rpx 28rpx 42rpx;
  color: #5a3b1e;
  background:
    linear-gradient(180deg, rgba(118, 76, 35, 0.28), rgba(244, 213, 170, 0.1) 28%, #f5d9b1 100%),
    radial-gradient(circle at 18% 20%, rgba(255, 250, 231, 0.86), transparent 34%),
    linear-gradient(135deg, #c7965c 0%, #f3d1a1 46%, #fff1d3 100%);
}

.learn-hero {
  min-height: 650rpx;
}

.learn-topbar {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.learn-back {
  width: 72rpx;
  height: 72rpx;
  padding: 0;
  border: 0;
  border-radius: 50%;
  background: rgba(255, 250, 237, 0.92);
  color: #8a5a26;
  font-size: 56rpx;
  line-height: 66rpx;
  box-shadow: 0 8rpx 18rpx rgba(88, 54, 25, 0.16);
}

.learn-back::after,
.learn-sector-card::after,
.learn-random-button::after,
.learn-start-button::after {
  border: 0;
}

.learn-title-block {
  min-width: 0;
  flex: 1;
}

.learn-title {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
  color: #fff9ef;
  text-shadow: 0 2rpx 8rpx rgba(76, 42, 16, 0.36);
}

.learn-subtitle {
  display: block;
  margin-top: 4rpx;
  font-size: 20rpx;
  color: rgba(255, 250, 239, 0.92);
}

.learn-resource-list {
  display: flex;
  gap: 12rpx;
}

.learn-resource {
  min-width: 108rpx;
  height: 56rpx;
  padding: 0 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border-radius: 28rpx;
  background: rgba(255, 250, 239, 0.95);
  box-shadow: 0 6rpx 16rpx rgba(96, 55, 22, 0.14);
}

.learn-resource-icon {
  font-size: 30rpx;
}

.learn-resource-value {
  font-size: 24rpx;
  font-weight: 700;
}

.learn-resource-plus {
  color: #c19a54;
  font-size: 26rpx;
  font-weight: 800;
}

.learn-research-desk {
  position: relative;
  min-height: 520rpx;
  margin-top: 68rpx;
  padding-top: 44rpx;
  border-radius: 30rpx;
  background:
    linear-gradient(180deg, rgba(255, 245, 224, 0.24), rgba(120, 77, 32, 0.14)),
    linear-gradient(90deg, rgba(91, 62, 35, 0.2) 1rpx, transparent 1rpx) 0 0 / 82rpx 100%;
}

.learn-speech {
  position: relative;
  width: 430rpx;
  min-height: 154rpx;
  padding: 34rpx 36rpx;
  border: 4rpx solid rgba(214, 174, 116, 0.72);
  border-radius: 26rpx;
  background: rgba(255, 249, 235, 0.94);
  box-shadow: 0 14rpx 28rpx rgba(96, 55, 22, 0.14);
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.55;
}

.learn-speech::after {
  content: "";
  position: absolute;
  right: -24rpx;
  bottom: 28rpx;
  width: 44rpx;
  height: 44rpx;
  background: rgba(255, 249, 235, 0.94);
  border-right: 4rpx solid rgba(214, 174, 116, 0.72);
  border-bottom: 4rpx solid rgba(214, 174, 116, 0.72);
  transform: rotate(-18deg);
}

.learn-cat-card {
  position: absolute;
  right: 18rpx;
  bottom: 4rpx;
  width: 410rpx;
  text-align: center;
}

.learn-cat-image {
  width: 380rpx;
  height: 380rpx;
  filter: drop-shadow(0 16rpx 18rpx rgba(78, 46, 20, 0.2));
}

.learn-nameplate {
  width: 220rpx;
  margin: -18rpx auto 0;
  padding: 12rpx 18rpx;
  border: 3rpx solid #c99c62;
  border-radius: 8rpx;
  background: rgba(255, 242, 216, 0.92);
  box-shadow: 0 6rpx 12rpx rgba(88, 55, 24, 0.12);
}

.learn-name,
.learn-role {
  display: block;
}

.learn-name {
  font-size: 26rpx;
  font-weight: 800;
}

.learn-role {
  margin-top: 2rpx;
  font-size: 20rpx;
  color: #80613f;
}

.learn-panel {
  margin-top: 24rpx;
  padding: 30rpx 28rpx 22rpx;
  border: 3rpx solid rgba(184, 137, 74, 0.58);
  border-radius: 26rpx;
  background: rgba(255, 244, 224, 0.95);
  box-shadow: 0 14rpx 32rpx rgba(93, 55, 23, 0.14);
}

.learn-panel-heading {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 18rpx;
}

.learn-leaf {
  color: #c7a260;
  font-size: 28rpx;
}

.learn-panel-title {
  font-size: 34rpx;
  font-weight: 900;
}

.learn-panel-subtitle {
  display: block;
  margin: 12rpx 0 26rpx;
  text-align: center;
  font-size: 24rpx;
  color: #725333;
}

.learn-sector-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.learn-sector-card {
  min-height: 256rpx;
  padding: 20rpx 16rpx;
  border: 3rpx solid rgba(196, 151, 92, 0.44);
  border-radius: 14rpx;
  background: #fff2d9;
  color: #54391f;
  text-align: center;
  box-shadow: 0 8rpx 16rpx rgba(107, 67, 30, 0.08);
}

.learn-sector-card-active {
  border-color: #f0a14c;
  background: #ffe8bd;
  box-shadow: 0 10rpx 22rpx rgba(188, 108, 35, 0.2);
}

.learn-sector-name {
  display: block;
  font-size: 28rpx;
  font-weight: 900;
}

.learn-sector-icon {
  height: 72rpx;
  margin: 18rpx 0 12rpx;
  font-size: 58rpx;
  line-height: 72rpx;
}

.learn-sector-desc {
  display: block;
  min-height: 66rpx;
  font-size: 22rpx;
  line-height: 1.5;
}

.learn-sector-tags {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 8rpx;
}

.learn-sector-tag {
  padding: 4rpx 10rpx;
  border-radius: 14rpx;
  background: rgba(237, 188, 119, 0.26);
  color: #95652f;
  font-size: 18rpx;
}

.learn-actions {
  margin-top: 30rpx;
  display: grid;
  grid-template-columns: 1fr 1.25fr;
  gap: 22rpx;
}

.learn-random-button,
.learn-start-button {
  min-height: 96rpx;
  padding: 12rpx 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  border-radius: 50rpx;
  color: #5b401f;
}

.learn-random-button {
  border: 3rpx solid #c4b172;
  background: #f3f0d0;
}

.learn-start-button {
  border: 3rpx solid #d69742;
  background: linear-gradient(180deg, #ffe594, #f0ab3f);
  box-shadow: 0 8rpx 16rpx rgba(166, 98, 22, 0.22);
}

.learn-action-icon {
  font-size: 34rpx;
}

.learn-action-copy {
  min-width: 0;
}

.learn-action-title,
.learn-action-subtitle {
  display: block;
}

.learn-action-title {
  font-size: 30rpx;
  font-weight: 900;
}

.learn-action-subtitle {
  margin-top: 2rpx;
  font-size: 20rpx;
  color: #725532;
}

.learn-arrow {
  margin-left: 8rpx;
  font-size: 48rpx;
  font-weight: 900;
  color: #9e6824;
}

.learn-footnote {
  display: block;
  margin-top: 16rpx;
  text-align: center;
  color: #b79a70;
  font-size: 20rpx;
}
